# =============================================
# Smart Subscription Management — .gitignore
# =============================================

# ---- Node.js / npm ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.pnpm-store

# ---- Environment (secrets) ----
.env
.env.local
.env.*.local

# ---- Build artifacts ----
dist/
build/
.vite/
*.tsbuildinfo

# ---- OS files ----
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ---- Logs ----
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# ---- Test coverage ----
coverage/
.nyc_output/

# ---- Docker ----
# Don't ignore docker-compose files or Dockerfiles

# ---- Prisma ----
# Keep migrations tracked (they are needed for deploy)
# Only ignore the generated client
backend/node_modules/.prisma/

# ---- Monitoring data ----
prometheus_data/
grafana_data/

# ---- Misc ----
*.tmp
*.bak
*.orig